{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/TellMe-1.0.dmg",
      "destination": "/TellMe-1.0.dmg"
    },
    {
      "source": "/TellMe-1.0.dmg.zip",
      "destination": "/TellMe-1.0.dmg.zip"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

